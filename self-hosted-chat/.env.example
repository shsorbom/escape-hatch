# === DOMAIN ===
DOMAIN=example.com

# === TIMEZONE ===
TZ=UTC

# === FRIEND CODE (shared secret for humans) ===
FRIEND_CODE=change-me-to-a-long-random-string

# === MATRIX / SYNAPSE ===
MATRIX_SERVER_NAME=example.com
MATRIX_SHARED_SECRET=change-me
POSTGRES_PASSWORD=change-me

# === SYNAPSE SECRETS ===
SYNAPSE_REGISTRATION_SHARED_SECRET=PUT_LONG_RANDOM_HEX_HERE
SYNAPSE_MACAROON_SECRET_KEY=PUT_LONG_RANDOM_HEX_HERE
SYNAPSE_FORM_SECRET=PUT_LONG_RANDOM_HEX_HERE

# === MUMBLE ===
MUMBLE_PASSWORD=change-me

# === BOTAMUSIQUE ===
BOTAMUSIQUE_VERSION=0.9.2
BOTAMUSIQUE_WEB_PASSWORD=change-me

# === LETSENCRYPT ===
EMAIL=admin@example.com
